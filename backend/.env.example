# Django
DJANGO_SECRET_KEY=your_django_secret_key_here
DEBUG=True
# Set to 'true' when running inside Docker to use PostgreSQL
# DOCKER_ENV=false

# Database (PostgreSQL) - Used when DOCKER_ENV=true
DB_NAME=watchtower
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# LLM Provider API Keys
GEMINI_API_KEY=your_gemini_api_key_here
